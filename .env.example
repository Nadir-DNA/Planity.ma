# ==================== Database ====================
DATABASE_URL="postgresql://user:password@localhost:5432/planity"

# ==================== Authentication ====================
NEXTAUTH_SECRET="your-secret-key-here"
NEXTAUTH_URL="http://localhost:3000"

# ==================== Redis (Rate Limiting) ====================
UPSTASH_REDIS_REST_URL="https://your-redis.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-token"

# ==================== Email (Resend) ====================
RESEND_API_KEY="re_xxx"

# ==================== Monitoring (Sentry) ====================
NEXT_PUBLIC_SENTRY_DSN="https://xxx@o448957.ingest.sentry.io/xxx"

# ==================== SMS (Optional) ====================
# Orange SMS API
ORANGE_SMS_API_KEY=""
ORANGE_SMS_CLIENT_ID=""
ORANGE_SMS_CLIENT_SECRET=""

# SMSAPI (alternative)
SMSAPI_KEY=""
SMSAPI_SECRET=""

# ==================== Map (Leaflet - Free) ====================
# No API key needed for OpenStreetMap tiles

# ==================== Stripe (Future) ====================
STRIPE_SECRET_KEY="sk_test_xxx"
STRIPE_PUBLISHABLE_KEY="pk_test_xxx"
STRIPE_WEBHOOK_SECRET="whsec_xxx"

# ==================== Supabase (Future) ====================
SUPABASE_URL="https://xxx.supabase.co"
SUPABASE_ANON_KEY="xxx"
SUPABASE_SERVICE_ROLE_KEY="xxx"

# ==================== Cloudflare Turnstile (CAPTCHA) ====================

# ==================== App Config ====================
NEXT_PUBLIC_APP_URL="https://planity.ma"
NEXT_PUBLIC_APP_NAME="Planity.ma"