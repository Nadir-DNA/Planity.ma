# Database
DATABASE_URL="postgresql://planity:planity_dev@localhost:5432/planity_ma?schema=public"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-change-in-production"

# Google OAuth (optional)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Stripe
STRIPE_SECRET_KEY=""
STRIPE_PUBLISHABLE_KEY=""
STRIPE_WEBHOOK_SECRET=""

# Redis
REDIS_URL="redis://localhost:6379"

# S3 / MinIO
S3_ENDPOINT="http://localhost:9000"
S3_ACCESS_KEY="planity_minio"
S3_SECRET_KEY="planity_minio_secret"
S3_BUCKET="planity-uploads"
S3_REGION="us-east-1"

# Email (Resend)
RESEND_API_KEY=""

# CMI Payment (Maroc)
CMI_MERCHANT_ID=""
CMI_API_KEY=""
CMI_API_SECRET=""
CMI_ENV="test" # "prod" for production

# SMS (Twilio / Infobip)
SMS_PROVIDER="twilio"
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""

# Google Maps
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=""

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
